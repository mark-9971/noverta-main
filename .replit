modules = ["nodejs-24", "postgresql-16"]

[deployment]
router = "application"
deploymentTarget = "autoscale"

[deployment.postBuild]
args = ["pnpm", "store", "prune"]
env = { "CI" = "true" }

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "incident-e2e"

[[workflows.workflow]]
name = "incident-e2e"
author = "agent"

[workflows.workflow.metadata]
isValidation = true

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "cd e2e && PLAYWRIGHT_CHROMIUM_EXECUTABLE_PATH=$(which chromium 2>/dev/null || echo '') npx playwright test tests/incident-lifecycle.spec.ts --list 2>&1 | grep -c 'incident-lifecycle' && npx tsc --noEmit"

[agent]
stack = "PNPM_WORKSPACE"
expertMode = true
integrations = ["stripe:1.0.0"]

[postMerge]
path = "scripts/post-merge.sh"
timeoutMs = 90000

[[ports]]
localPort = 8080
externalPort = 80

[[ports]]
localPort = 8081
externalPort = 8081

[[ports]]
localPort = 8082
externalPort = 4200

[[ports]]
localPort = 8083
externalPort = 5000

[[ports]]
localPort = 20180
externalPort = 3001

[[ports]]
localPort = 20181
externalPort = 8000

[[ports]]
localPort = 20182
externalPort = 8080

[[ports]]
localPort = 22248
externalPort = 3000

[[ports]]
localPort = 22249
externalPort = 3003

[[ports]]
localPort = 22250
externalPort = 5173

[[ports]]
localPort = 25405
externalPort = 6000

[[ports]]
localPort = 25736
externalPort = 3002

[[ports]]
localPort = 25737
externalPort = 6800

[[ports]]
localPort = 25738
externalPort = 8099

[nix]
channel = "stable-25_05"

[userenv]

[userenv.development]
NODE_ENV = "test"
