modules = ["nodejs-24", "postgresql-16"]

[deployment]
router = "application"
deploymentTarget = "autoscale"

[deployment.postBuild]
args = ["pnpm", "store", "prune"]
env = { "CI" = "true" }

[workflows]

[agent]
stack = "PNPM_WORKSPACE"
expertMode = true
integrations = ["stripe:1.0.0"]

[postMerge]
path = "scripts/post-merge.sh"
timeoutMs = 90000

[[ports]]
localPort = 8080
externalPort = 80

[[ports]]
localPort = 22248
externalPort = 3000

[nix]
channel = "stable-25_05"

[userenv]

[userenv.development]

[userenv.shared]
VITE_SENTRY_DSN = "https://9df57583c8780b2677f1310ae418620d@o4511242208149504.ingest.us.sentry.io/4511242209787904"
SENTRY_DSN = "https://0ffda1bd03866e01b46d9f490c21067b@o4511242208149504.ingest.us.sentry.io/4511242231480320"

[objectStorage]
defaultBucketID = "replit-objstore-9585515c-75e2-4dab-b42d-7b5a1844bc76"
