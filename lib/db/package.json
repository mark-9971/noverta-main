{
  "name": "@workspace/db",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": "./src/index.ts",
    "./schema": "./src/schema/index.ts"
  },
  "scripts": {
    "push": "drizzle-kit push --config ./drizzle.config.ts",
    "push-force": "drizzle-kit push --force --config ./drizzle.config.ts",
    "migrate": "tsx ./run-migrations.ts",
    "check-drift": "tsx ./run-check-schema-drift.ts",
    "sync-test-db": "node ./scripts/sync-test-db.mjs",
    "report-uncoupled-overlaps": "tsx ./src/scripts/report-uncoupled-overlaps.ts"
  },
  "dependencies": {
    "@workspace/tiers": "workspace:*",
    "drizzle-orm": "catalog:",
    "drizzle-zod": "^0.8.3",
    "pg": "^8.20.0",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@types/node": "catalog:",
    "@types/pg": "^8.18.0",
    "drizzle-kit": "^0.31.9",
    "tsx": "catalog:"
  }
}
